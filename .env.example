# Copiez ce fichier en .env si besoin (optionnel pour le développement local)

# Django
SECRET_KEY=changez-moi-en-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Production (Render, etc.) — PostgreSQL recommandé pour plusieurs utilisateurs
# DATABASE_URL=postgres://utilisateur:motdepasse@hote:5432/nom_de_la_base
# Sur Render, utilisez l'URL fournie par le service PostgreSQL.

# --- Optionnel : IA payante (vous n'en avez PAS besoin) ---
# L'application fonctionne entièrement sans cette clé.
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

